{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "codegraph": {
      "type": "local",
      "command": [
        "codegraph",
        "serve",
        "--mcp"
      ],
      "enabled": true
    },
    "headroom": {
      "type": "local",
      "command": [
        "headroom",
        "mcp",
        "serve"
      ],
      "enabled": true
    }
  }
}
